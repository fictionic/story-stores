{
  "name": "story-stores",
  "description": "A small Zustand-inspired state management library built around inter-store subscriptions",
  "keywords": ["state-management", "zustand", "immer", "react", "store", "story"],
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "default": "./dist/vanilla.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "bunx tsc --noEmit",
    "prepack": "tsup"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "dependencies": {
    "immer": "^11"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "5",
    "vitest": "^4.1.0"
  }
}
